{
  "manifest_version": 3,
  "name": "Steam F2P Tracker",
  "version": "1.5.0",
  "description": "Auto-detect, queue, and push free-to-play Steam games to a GitHub tracker repository.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/app/*"
      ],
      "js": [
        "content/ns.js",
        "content/lib-dom.js",
        "content/extract-price.js",
        "content/extract-type.js",
        "content/extract-platform.js",
        "content/extract-anticheat.js",
        "content/extract-metadata.js",
        "content/extract-lang-tags.js",
        "content/detector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
